  document.getElementById('th-header').value = themeData.header;
  document.getElementById('th-cell').value = themeData.cell;
}

function renderPresets() {
  const grid = document.getElementById('preset-grid');
  if (!grid) return;
  grid.innerHTML = '';
  THEME_PRESETS.forEach((p, i) => {
    const btn = document.createElement('button');
    btn.className = 'preset-btn';
    btn.id = `preset-btn-${i}`;
    btn.style.background = p.bg;
    btn.style.borderColor = p.accent + '55';
    btn.style.color = p.accent;
    btn.innerHTML = `
      <div class="preset-swatch" style="background: linear-gradient(135deg, ${p.header} 0%, ${p.cell} 50%, ${p.bg} 100%); border: 1px solid ${p.accent}44;"></div>
      <span>${p.emoji} ${p.name}</span>
    `;
    btn.onclick = () => applyPreset(i);
    grid.appendChild(btn);
  });
}

function applyPreset(i) {
  const p = THEME_PRESETS[i];
  themeData = { ...p };
  syncThemeInputs();
  applyTheme();
  // highlight selected
  document.querySelectorAll('.preset-btn').forEach((b,idx) => b.classList.toggle('selected', idx===i));
  showToast(`Theme: ${p.name}!`);
}

