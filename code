function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

function applyTheme() {
  const root = document.documentElement;
  root.style.setProperty('--theme-accent', themeData.accent);
  root.style.setProperty('--theme-accent-rgb', hexToRgb(themeData.accent));
  root.style.setProperty('--theme-bg', themeData.bg);
  root.style.setProperty('--theme-bg2', themeData.bg2);
  root.style.setProperty('--theme-bg3', themeData.bg3);
  root.style.setProperty('--theme-header-bg', themeData.header);
  root.style.setProperty('--theme-cell-bg', themeData.cell);
  // Also update the gold vars so everything follows accent
  root.style.setProperty('--gold', themeData.accent);
  root.style.setProperty('--gold2', themeData.accent);
  root.style.setProperty('--gold-dim', themeData.accent + '99');
  root.style.setProperty('--gold-glow', `0 0 18px rgba(${hexToRgb(themeData.accent)},0.6), 0 0 40px rgba(${hexToRgb(themeData.accent)},0.2)`);
  root.style.setProperty('--border', `rgba(${hexToRgb(themeData.accent)},0.25)`);
  root.style.setProperty('--navy', themeData.bg);
  root.style.setProperty('--navy2', themeData.bg2);
  root.style.setProperty('--navy3', themeData.bg3);
  root.style.setProperty('--blue-mid', themeData.header);
  root.style.setProperty('--cell-bg', themeData.cell);
  updateThemePreview();
  // Update setup screen
  const setupIcon = document.getElementById('setup-icon');
  if (setupIcon) setupIcon.textContent = themeData.icon;
  const setupTitle = document.getElementById('setup-title');
  if (setupTitle) setupTitle.textContent = themeData.title;
  const setupSub = document.getElementById('setup-sub');
  if (setupSub) setupSub.textContent = themeData.subtitle;
  // Update board logo if on board screen
  const logo = document.getElementById('board-logo-text');
  if (logo) logo.textContent = `${themeData.icon} ${themeData.title}`;
}

function updateThemePreview() {
  const accent = themeData.accent;
  const bg = themeData.bg;
  const header = themeData.header;
  const cell = themeData.cell;
  const accentRgb = hexToRgb(accent);

  const box = document.getElementById('theme-preview-box');
  if (box) box.style.background = bg;

  const icon = document.getElementById('preview-icon');
  if (icon) icon.textContent = themeData.icon;

  const title = document.getElementById('preview-title');
  if (title) { title.textContent = themeData.title; title.style.color = accent; title.style.textShadow = `0 0 15px rgba(${accentRgb},0.6)`; }

  const sub = document.getElementById('preview-sub');
  if (sub) { sub.textContent = themeData.subtitle; }

  ['ph0','ph1','ph2'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.style.background = header; el.style.color = '#fff'; el.style.borderBottom = `1px solid rgba(${accentRgb},0.3)`; }
  });
  ['pc0','pc1','pc2','pc3','pc4','pc5'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.style.background = cell; el.style.color = accent; el.style.border = `1px solid rgba(${accentRgb},0.2)`; }
  });
}

function syncThemeInputs() {
  document.getElementById('th-title').value = themeData.title;
  document.getElementById('th-subtitle').value = themeData.subtitle;
  document.getElementById('th-icon').value = themeData.icon;
