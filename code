<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>D&D Jeopardy — Realms of Knowledge</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0b0e2a;
  --navy2: #111435;
  --navy3: #181c42;
  --blue-mid: #1a2060;
  --cell-bg: #0e1540;
  --cell-hover: #1a2272;
  --gold: #e8c84a;
  --gold2: #f5d76e;
  --gold-dim: #9a8030;
  --gold-glow: 0 0 18px rgba(232,200,74,0.6), 0 0 40px rgba(232,200,74,0.2);
  --silver: #c8d0e0;
  --red: #c0392b;
  --red2: #e74c3c;
  --green: #1a7a3a;
  --green2: #27ae60;
  --white: #f0f4ff;
  --border: rgba(232,200,74,0.25);
  --cat-colors: #7b1fa2, #1565c0, #2e7d32, #c62828, #e65100, #00695c;
  /* Theme-overridable */
  --theme-accent: #e8c84a;
  --theme-accent-rgb: 232,200,74;
  --theme-bg: #0b0e2a;
  --theme-bg2: #111435;
  --theme-bg3: #181c42;
  --theme-header-bg: #1a2060;
  --theme-cell-bg: #0e1540;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--theme-bg);
  color: var(--white);
  font-family: 'Crimson Text', serif;
  min-height: 100vh;
  overflow-x: hidden;
  background-image:
    radial-gradient(ellipse at 30% 0%, rgba(27,32,96,0.8) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 100%, rgba(11,14,42,1) 0%, transparent 60%),
    repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(var(--theme-accent-rgb),0.02) 60px, rgba(var(--theme-accent-rgb),0.02) 61px),
    repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(var(--theme-accent-rgb),0.02) 60px, rgba(var(--theme-accent-rgb),0.02) 61px);
}

/* ═══════════════════════════════════════
   SCREENS
═══════════════════════════════════════ */
.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; flex-direction: column; align-items: center; }

/* ═══════════════════════════════════════
   SETUP SCREEN
═══════════════════════════════════════ */
#setup-screen {
  justify-content: center;
  padding: 40px 20px;
  gap: 28px;
}

.logo-wrap { text-align: center; }
.logo-dnd { font-size: 64px; filter: drop-shadow(0 0 20px var(--gold)); animation: float 4s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

.game-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(22px, 4vw, 40px);
  color: var(--gold);
  text-shadow: var(--gold-glow);
  line-height: 1.15;
  text-align: center;
}
.game-sub {
  font-family: 'Cinzel', serif;
  font-size: 14px;
  color: var(--silver);
  letter-spacing: 4px;
  text-align: center;
  opacity: 0.7;
  text-transform: uppercase;
}

.gold-rule { width: 320px; height: 1px; background: linear-gradient(90deg,transparent,var(--gold),transparent); }

.setup-card {
  background: var(--navy2);
  border: 1px solid var(--border);
  padding: 28px 32px;
  width: 100%;
  max-width: 520px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.setup-card h2 {
  font-family: 'Cinzel', serif;
  font-size: 15px;
  color: var(--gold);
  letter-spacing: 3px;
  text-transform: uppercase;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

.player-row {
  display: flex;
  gap: 8px;
  align-items: center;
}
.player-row input[type="text"] {
  flex: 1;
  background: var(--navy3);
  border: 1px solid var(--border);
  color: var(--white);
  padding: 10px 14px;
  font-family: 'Crimson Text', serif;
  font-size: 17px;
  outline: none;
  transition: border-color 0.2s;
}
.player-row input:focus { border-color: var(--gold); }
.color-dot {
  width: 28px; height: 28px;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2px solid rgba(255,255,255,0.2);
}
.remove-player {
  background: none;
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.4);
  width: 28px; height: 28px;
  cursor: pointer;
  font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
  border-radius: 2px;
}
.remove-player:hover { border-color: var(--red); color: var(--red); }

.add-player-btn {
  background: none;
  border: 1px dashed var(--border);
  color: var(--gold-dim);
  padding: 9px;
  cursor: pointer;
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 2px;
  transition: all 0.2s;
}
.add-player-btn:hover { border-color: var(--gold); color: var(--gold); }

.btn-gold {
  font-family: 'Cinzel', serif;
  font-weight: 700;
  font-size: 16px;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 15px 40px;
  background: linear-gradient(135deg, #8a6a00, var(--gold), #8a6a00);
  background-size: 200% 100%;
  border: none;
  color: var(--navy);
  cursor: pointer;
  transition: all 0.3s;
  clip-path: polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.btn-gold:hover { background-position: right; box-shadow: var(--gold-glow); transform: translateY(-2px); }

.btn-ghost {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 2px;
  padding: 10px 24px;
  background: none;
  border: 1px solid var(--border);
  color: var(--silver);
  cursor: pointer;
  transition: all 0.2s;
}
.btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

/* ═══════════════════════════════════════
   EDITOR SCREEN
═══════════════════════════════════════ */
#editor-screen {
  padding: 30px 20px;
  gap: 20px;
  max-width: 960px;
  width: 100%;
  margin: 0 auto;
}

.editor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}
.editor-header h1 {
  font-family: 'Cinzel', serif;
  font-size: 20px;
  color: var(--gold);
  letter-spacing: 2px;
}

.editor-tabs {
  display: flex;
  gap: 6px;
  width: 100%;
  flex-wrap: wrap;
}
.editor-tab {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  letter-spacing: 1px;
  padding: 8px 16px;
  background: var(--navy2);
  border: 1px solid var(--border);
  color: var(--silver);
  cursor: pointer;
  transition: all 0.2s;
  flex: 1;
  min-width: 100px;
  text-align: center;
  text-transform: uppercase;
}
.editor-tab.active { background: var(--blue-mid); border-color: var(--gold); color: var(--gold); }
.editor-tab:hover:not(.active) { border-color: rgba(232,200,74,0.5); color: var(--gold2); }

.cat-editor { width: 100%; display: none; flex-direction: column; gap: 12px; }
.cat-editor.active { display: flex; }

.cat-name-row {
  display: flex;
  gap: 10px;
  align-items: center;
}
.cat-name-row input {
  flex: 1;
  background: var(--navy3);
  border: 1px solid var(--border);
  color: var(--gold2);
  padding: 10px 14px;
  font-family: 'Cinzel', serif;
  font-size: 15px;
  letter-spacing: 2px;
  outline: none;
}
.cat-name-row input:focus { border-color: var(--gold); }

.q-editor-block {
  background: var(--navy2);
  border: 1px solid var(--border);
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.q-editor-block .q-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.q-pts-badge {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  color: var(--gold);
  background: rgba(232,200,74,0.08);
  border: 1px solid var(--border);
  padding: 3px 10px;
  letter-spacing: 1px;
}
.q-editor-block label {
  font-size: 12px;
  color: var(--gold-dim);
  letter-spacing: 2px;
  text-transform: uppercase;
  font-family: 'Cinzel', serif;
}
.q-editor-block input[type="text"],
.q-editor-block textarea {
  background: var(--navy3);
  border: 1px solid rgba(232,200,74,0.15);
  color: var(--white);
  padding: 9px 12px;
  font-family: 'Crimson Text', serif;
  font-size: 16px;
  outline: none;
  width: 100%;
  transition: border-color 0.2s;
  resize: vertical;
}
.q-editor-block input:focus,
.q-editor-block textarea:focus { border-color: var(--gold); }
.q-editor-block textarea { min-height: 60px; }

.answers-editor { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.answer-edit-row { display: flex; gap: 6px; align-items: center; }
.answer-edit-row .ans-letter {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  color: var(--gold);
  width: 22px;
  flex-shrink: 0;
  text-align: center;
}
.answer-edit-row input { flex: 1; }
.correct-radio {
  accent-color: var(--gold);
  width: 16px; height: 16px;
  cursor: pointer;
  flex-shrink: 0;
}
.correct-label { font-size: 11px; color: var(--green2); font-family: 'Cinzel', serif; letter-spacing: 1px; }

/* ═══════════════════════════════════════
   BOARD SCREEN
═══════════════════════════════════════ */
#board-screen {
  padding: 16px;
  gap: 14px;
  width: 100%;
}

.board-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: 1100px;
  gap: 12px;
}
.board-logo {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(14px, 2vw, 22px);
  color: var(--gold);
  text-shadow: var(--gold-glow);
  white-space: nowrap;
}

.scoreboard {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.score-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--navy2);
  border: 2px solid transparent;
  padding: 6px 14px;
  min-width: 90px;
  transition: all 0.3s;
}
.score-chip.active-player { border-color: var(--gold); box-shadow: var(--gold-glow); }
.score-name {
  font-family: 'Cinzel', serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 2px;
}
.score-val {
  font-family: 'Cinzel Decorative', serif;
  font-size: 20px;
  color: var(--gold);
}
.score-val.negative { color: var(--red2); }

/* THE BOARD */
.jeopardy-board {
  width: 100%;
  max-width: 1100px;
  display: grid;
  gap: 6px;
}

.cat-header {
  background: var(--blue-mid);
  border: 1px solid var(--border);
  padding: 12px 8px;
  text-align: center;
  font-family: 'Cinzel', serif;
  font-size: clamp(10px, 1.5vw, 14px);
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60px;
  line-height: 1.3;
}

.board-cell {
  background: var(--cell-bg);
  border: 1px solid rgba(232,200,74,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s;
  min-height: 70px;
  padding: 8px;
  position: relative;
  overflow: hidden;
}
.board-cell::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, rgba(232,200,74,0.08), transparent 70%);
  opacity: 0;
  transition: opacity 0.15s;
}
.board-cell:hover:not(.used)::before { opacity: 1; }
.board-cell:hover:not(.used) { border-color: var(--gold); transform: scale(1.03); z-index: 2; box-shadow: var(--gold-glow); }
.board-cell.used { background: var(--navy); opacity: 0.2; cursor: default; pointer-events: none; }
.cell-pts {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(18px, 2.5vw, 32px);
  color: var(--gold);
  text-shadow: var(--gold-glow);
}

/* ═══════════════════════════════════════
   QUESTION MODAL
═══════════════════════════════════════ */
.modal-bg {
  position: fixed;
  inset: 0;
  background: rgba(5, 8, 28, 0.92);
  backdrop-filter: blur(6px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 20px;
}
.modal-bg.open { display: flex; }

.modal-card {
  background: var(--navy2);
  border: 2px solid var(--gold);
  box-shadow: var(--gold-glow), inset 0 0 60px rgba(11,14,42,0.5);
  padding: 40px 44px;
  max-width: 680px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20px;
  animation: modal-in 0.35s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
}
@keyframes modal-in {
  from { transform: scale(0.85) translateY(20px); opacity: 0; }
  to { transform: scale(1) translateY(0); opacity: 1; }
}

.modal-cat {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 4px;
  color: var(--gold);
  text-transform: uppercase;
  opacity: 0.7;
  text-align: center;
}
.modal-pts {
  font-family: 'Cinzel Decorative', serif;
  font-size: 48px;
  color: var(--gold);
  text-shadow: var(--gold-glow);
  text-align: center;
  line-height: 1;
}
.modal-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }

.modal-clue {
  font-size: clamp(20px, 3vw, 28px);
  color: var(--white);
  text-align: center;
  line-height: 1.5;
  font-style: italic;
}

/* Player buzzer buttons */
.buzzer-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.buzzer-label {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  letter-spacing: 3px;
  color: var(--gold-dim);
  text-align: center;
  text-transform: uppercase;
}
.buzzer-grid {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}
.buzzer-btn {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 1px;
  padding: 12px 20px;
  border: 2px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  min-width: 100px;
  text-align: center;
  font-weight: 700;
}
.buzzer-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.4); }
.buzzer-btn.selected-buzzer { transform: scale(1.08); outline: 3px solid white; }

/* Answer reveal */
.answer-reveal {
  display: none;
  flex-direction: column;
  gap: 14px;
}
.answer-reveal.open { display: flex; }
.answer-text {
  font-family: 'Cinzel', serif;
  font-size: 20px;
  color: var(--gold2);
  text-align: center;
  padding: 14px 20px;
  background: rgba(232,200,74,0.06);
  border: 1px solid var(--border);
  letter-spacing: 1px;
}
.judge-label {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  letter-spacing: 3px;
  color: var(--silver);
  text-align: center;
  text-transform: uppercase;
}
.judge-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
}
.btn-correct {
  background: var(--green);
  border: 2px solid var(--green2);
  color: white;
  font-family: 'Cinzel', serif;
  font-size: 15px;
  letter-spacing: 2px;
  padding: 12px 30px;
  cursor: pointer;
  transition: all 0.2s;
}
.btn-correct:hover { background: var(--green2); transform: translateY(-1px); }
.btn-wrong {
  background: var(--red);
  border: 2px solid var(--red2);
  color: white;
  font-family: 'Cinzel', serif;
  font-size: 15px;
  letter-spacing: 2px;
  padding: 12px 30px;
  cursor: pointer;
  transition: all 0.2s;
}
.btn-wrong:hover { background: var(--red2); transform: translateY(-1px); }

.modal-skip {
  background: none;
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.35);
  font-family: 'Cinzel', serif;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 8px 20px;
  cursor: pointer;
  align-self: center;
  transition: all 0.2s;
}
.modal-skip:hover { border-color: var(--gold-dim); color: var(--gold-dim); }

/* ═══════════════════════════════════════
   END SCREEN
═══════════════════════════════════════ */
#end-screen {
  justify-content: center;
  padding: 40px 20px;
  gap: 28px;
  text-align: center;
}
.end-trophy { font-size: 80px; animation: float 3s ease-in-out infinite; }
.end-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(26px, 5vw, 50px);
  color: var(--gold);
  text-shadow: var(--gold-glow);
}
.end-results {
  display: flex;
  flex-direction: column;
  gap: 10px;
  width: 100%;
  max-width: 420px;
}
.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  background: var(--navy2);
  border: 1px solid var(--border);
}
.result-row.winner { border-color: var(--gold); box-shadow: var(--gold-glow); }
.result-rank {
  font-family: 'Cinzel Decorative', serif;
  font-size: 22px;
  color: var(--gold);
  width: 36px;
}
.result-name {
  font-family: 'Cinzel', serif;
  font-size: 16px;
  letter-spacing: 2px;
  flex: 1;
  text-align: left;
  margin-left: 12px;
}
.result-score {
  font-family: 'Cinzel Decorative', serif;
  font-size: 22px;
  color: var(--gold2);
}
.result-score.neg { color: var(--red2); }

/* Notification toast */
.toast {
  position: fixed;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--navy2);
  border: 1px solid var(--gold);
  padding: 12px 28px;
  font-family: 'Cinzel', serif;
  font-size: 14px;
  color: var(--gold);
  letter-spacing: 2px;
  z-index: 1000;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  white-space: nowrap;
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.correct-toast { border-color: var(--green2); color: var(--green2); }
.toast.wrong-toast { border-color: var(--red2); color: var(--red2); }

/* Daily double flash */
.daily-double-flash {
  position: fixed;
  inset: 0;
  background: var(--navy);
  z-index: 300;
  display: none;
  align-items: center;
  justify-content: center;
}
.daily-double-flash.show { display: flex; animation: dd-flash 2s forwards; }
@keyframes dd-flash {
  0% { opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; pointer-events: none; }
}
.dd-text {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(40px, 8vw, 80px);
  color: var(--gold);
  text-shadow: var(--gold-glow);
  animation: dd-scale 2s forwards;
}
@keyframes dd-scale {
  0% { transform: scale(0.5); opacity: 0; }
  30% { transform: scale(1.1); opacity: 1; }
  70% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.05); opacity: 0; }
}

/* ═══════════════════════════════════════
   THEME EDITOR
═══════════════════════════════════════ */
.theme-editor-panel {
  width: 100%;
  display: none;
  flex-direction: column;
  gap: 20px;
}
.theme-editor-panel.active { display: flex; }

.theme-section {
  background: var(--navy2);
  border: 1px solid var(--border);
  padding: 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.theme-section h3 {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  color: var(--gold);
  letter-spacing: 3px;
  text-transform: uppercase;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

.theme-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}
.theme-row label {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  color: var(--silver);
  letter-spacing: 1px;
  min-width: 130px;
  flex-shrink: 0;
}
.theme-row input[type="text"] {
  flex: 1;
  min-width: 160px;
  background: var(--navy3);
  border: 1px solid var(--border);
  color: var(--white);
  padding: 9px 12px;
  font-family: 'Crimson Text', serif;
  font-size: 16px;
  outline: none;
  transition: border-color 0.2s;
