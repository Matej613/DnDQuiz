  document.getElementById(id).classList.add('active');
}
function showSetup() { showScreen('setup-screen'); renderPlayerList(); }
function showEditor() { renderEditor(); showScreen('editor-screen'); }
function saveAndBack() { applyTheme(); showSetup(); showToast('Saved!'); }

// ════════════════════════════════════════════════════════
//  PLAYERS
// ════════════════════════════════════════════════════════

function initDefaultPlayers() {
  players = [
    { name: 'Player 1', color: PLAYER_COLORS[0], score: 0 },
    { name: 'Player 2', color: PLAYER_COLORS[1], score: 0 },
  ];
}

function renderPlayerList() {
  const list = document.getElementById('player-list');
  list.innerHTML = '';
  players.forEach((p, i) => {
    const row = document.createElement('div');
    row.className = 'player-row';
    row.innerHTML = `
      <div class="color-dot" style="background:${p.color}"></div>
      <input type="text" value="${p.name}" placeholder="Adventurer name" oninput="players[${i}].name=this.value" />
      <button class="remove-player" onclick="removePlayer(${i})" title="Remove">✕</button>
    `;
    list.appendChild(row);
  });
}

function addPlayer() {
  if (players.length >= 8) { showToast('Max 8 adventurers!'); return; }
  players.push({ name: `Player ${players.length + 1}`, color: PLAYER_COLORS[players.length % PLAYER_COLORS.length], score: 0 });
  renderPlayerList();
}

function removePlayer(i) {
  if (players.length <= 1) { showToast('Need at least 1 adventurer!'); return; }
  players.splice(i, 1);
  renderPlayerList();
}

// ════════════════════════════════════════════════════════
//  EDITOR
// ════════════════════════════════════════════════════════

function renderEditor() {
  const tabs = document.getElementById('editor-tabs');
  const content = document.getElementById('editor-content');
  const themePanel = document.getElementById('theme-editor-panel');
  tabs.innerHTML = '';
  content.innerHTML = '';

  // ── THEME TAB ──
  const themeTab = document.createElement('button');
  themeTab.className = 'editor-tab active';
  themeTab.id = 'tab-theme';
  themeTab.textContent = '🎨 Theme';
  themeTab.onclick = () => switchEditorTab('theme');
  tabs.appendChild(themeTab);

  // ── CATEGORY TABS ──
  gameData.categories.forEach((cat, ci) => {
    const tab = document.createElement('button');
    tab.className = 'editor-tab';
    tab.id = `tab-cat-${ci}`;
    tab.textContent = cat.name || `Category ${ci+1}`;
    tab.onclick = () => switchEditorTab(ci);
    tabs.appendChild(tab);

    const panel = document.createElement('div');
    panel.className = 'cat-editor';
    panel.id = `cat-editor-${ci}`;

    let html = `
      <div class="cat-name-row">
        <input type="text" value="${cat.name}" placeholder="Category Name"
          oninput="gameData.categories[${ci}].name=this.value; document.getElementById('tab-cat-${ci}').textContent=this.value||'Category ${ci+1}'" />
      </div>
    `;

    cat.questions.forEach((q, qi) => {
      const pts = POINTS[qi];
      html += `
        <div class="q-editor-block">
          <div class="q-header">
            <span class="q-pts-badge">${pts} pts</span>
            <label style="display:flex;align-items:center;gap:6px; cursor:pointer;">
              <input type="checkbox" ${q.dailyDouble ? 'checked' : ''} onchange="gameData.categories[${ci}].questions[${qi}].dailyDouble=this.checked" style="accent-color:var(--gold);width:16px;height:16px;" />
              <span style="font-family:'Cinzel',serif;font-size:11px;color:var(--gold);letter-spacing:1px;">DAILY DOUBLE</span>
            </label>
          </div>
          <label>Clue (what the host reads)</label>
          <textarea oninput="gameData.categories[${ci}].questions[${qi}].clue=this.value">${q.clue}</textarea>
          <label>Answer (the correct response)</label>
          <input type="text" value="${q.answer}" oninput="gameData.categories[${ci}].questions[${qi}].answer=this.value" placeholder='e.g. "What is a Beholder?"' />
        </div>
      `;
    });

    panel.innerHTML = html;
    content.appendChild(panel);
  });

  // Show theme panel by default
  themePanel.classList.add('active');
  content.style.display = 'none';

  // Sync theme inputs & render presets
  syncThemeInputs();
  renderPresets();
  updateThemePreview();
}

function switchEditorTab(which) {
  const themePanel = document.getElementById('theme-editor-panel');
  const content = document.getElementById('editor-content');

  document.querySelectorAll('.editor-tab').forEach(t => t.classList.remove('active'));

  if (which === 'theme') {
    document.getElementById('tab-theme').classList.add('active');
    themePanel.classList.add('active');
    content.style.display = 'none';
  } else {
    document.getElementById(`tab-cat-${which}`).classList.add('active');
    themePanel.classList.remove('active');
    content.style.display = 'block';
    document.querySelectorAll('.cat-editor').forEach(e => e.classList.remove('active'));
    document.getElementById(`cat-editor-${which}`).classList.add('active');
  }
}

// ════════════════════════════════════════════════════════
//  GAME START
// ════════════════════════════════════════════════════════

function startGame() {
  if (players.length === 0) { showToast('Add at least one player!'); return; }
  // Reset scores
  players.forEach(p => p.score = 0);
  usedCells = new Set();
  activePlayerIdx = 0;

  applyTheme();
  const logo = document.getElementById('board-logo-text');
  if (logo) logo.textContent = `${themeData.icon} ${themeData.title}`;

  buildBoard();
  renderScoreboard();
  showScreen('board-screen');
}

function buildBoard() {
  const board = document.getElementById('jeopardy-board');
  const numCats = gameData.categories.length;
  board.style.gridTemplateColumns = `repeat(${numCats}, 1fr)`;

  board.innerHTML = '';

  // Headers
  gameData.categories.forEach((cat, ci) => {
    const hdr = document.createElement('div');
    hdr.className = 'cat-header';
    hdr.style.borderTopColor = PLAYER_COLORS[ci % PLAYER_COLORS.length];
    hdr.style.borderTopWidth = '3px';
    hdr.style.borderTopStyle = 'solid';
    hdr.textContent = cat.name.toUpperCase();
    board.appendChild(hdr);
  });

  // Cells
  POINTS.forEach((pts, qi) => {
    gameData.categories.forEach((cat, ci) => {
      const cell = document.createElement('div');
      const key = `${ci}-${qi}`;
      cell.className = 'board-cell' + (usedCells.has(key) ? ' used' : '');
      cell.id = `cell-${ci}-${qi}`;
      cell.innerHTML = `<span class="cell-pts">${pts}</span>`;
      cell.onclick = () => openQuestion(ci, qi);
      board.appendChild(cell);
    });
  });
}

function renderScoreboard() {
  const sb = document.getElementById('scoreboard');
  sb.innerHTML = '';
  players.forEach((p, i) => {
    const chip = document.createElement('div');
    chip.className = 'score-chip' + (i === activePlayerIdx ? ' active-player' : '');
    chip.id = `score-chip-${i}`;
    chip.innerHTML = `
      <div class="score-name" style="color:${p.color}">${p.name}</div>
      <div class="score-val ${p.score < 0 ? 'negative' : ''}" id="score-val-${i}">${p.score.toLocaleString()}</div>
    `;
    sb.appendChild(chip);
  });
}

function updateScoreboard() {
  players.forEach((p, i) => {
    const chip = document.getElementById(`score-chip-${i}`);
    if (chip) chip.className = 'score-chip' + (i === activePlayerIdx ? ' active-player' : '');
    const val = document.getElementById(`score-val-${i}`);
    if (val) {
      val.textContent = p.score.toLocaleString();
      val.className = 'score-val' + (p.score < 0 ? ' negative' : '');
    }
  });
}

// ════════════════════════════════════════════════════════
//  QUESTION FLOW
// ════════════════════════════════════════════════════════

function openQuestion(ci, qi) {
  const key = `${ci}-${qi}`;
  if (usedCells.has(key)) return;

  currentCell = { ci, qi };
  buzzedPlayerIdx = null;

  const cat = gameData.categories[ci];
  const q = cat.questions[qi];
  const pts = POINTS[qi];

  // Daily double?
  if (q.dailyDouble) {
    const flash = document.getElementById('dd-flash');
    flash.classList.add('show');
    setTimeout(() => {
      flash.classList.remove('show');
      openModal(cat, q, pts);
    }, 2000);
  } else {
    openModal(cat, q, pts);
  }
}

function openModal(cat, q, pts) {
  document.getElementById('modal-cat').textContent = cat.name.toUpperCase();
  document.getElementById('modal-pts').textContent = pts;
  document.getElementById('modal-clue').textContent = q.clue;
  document.getElementById('answer-text').textContent = q.answer;

  document.getElementById('answer-reveal').classList.remove('open');
  document.getElementById('close-modal-btn').style.display = 'none';
  document.getElementById('buzzer-section').style.display = 'flex';

  // Build buzzer buttons
  const grid = document.getElementById('buzzer-grid');
  grid.innerHTML = '';
  players.forEach((p, i) => {
    const btn = document.createElement('button');
    btn.className = 'buzzer-btn';
    btn.style.background = p.color + '22';
    btn.style.borderColor = p.color;
    btn.style.color = p.color;
    btn.textContent = p.name;
    btn.id = `buzz-${i}`;
    btn.onclick = () => selectBuzzer(i);
    grid.appendChild(btn);
  });

  document.getElementById('modal-bg').classList.add('open');
}

function selectBuzzer(i) {
  buzzedPlayerIdx = i;
  document.querySelectorAll('.buzzer-btn').forEach((b, idx) => {
    b.classList.toggle('selected-buzzer', idx === i);
  });
  revealAnswer();
}

function revealAnswer() {
  document.getElementById('buzzer-section').style.display = 'none';
  const rev = document.getElementById('answer-reveal');
  rev.classList.add('open');

  if (buzzedPlayerIdx === null) {
    document.getElementById('judge-prompt').textContent = 'Nobody answered — mark used:';
    document.querySelector('.btn-correct').textContent = '✔ Skip (no points)';
    document.querySelector('.btn-wrong').style.display = 'none';
  } else {
    const p = players[buzzedPlayerIdx];
    document.getElementById('judge-prompt').textContent = `${p.name} answered — correct?`;
    document.querySelector('.btn-correct').textContent = '✔ Correct!';
    document.querySelector('.btn-wrong').style.display = '';
    document.querySelector('.btn-wrong').textContent = '✘ Wrong!';
  }
}

function judgeAnswer(isCorrect) {
  const { ci, qi } = currentCell;
  const pts = POINTS[qi];

  if (buzzedPlayerIdx !== null) {
    if (isCorrect) {
      players[buzzedPlayerIdx].score += pts;
      activePlayerIdx = buzzedPlayerIdx;
      showToast(`+${pts} for ${players[buzzedPlayerIdx].name}!`, 'correct-toast');
    } else {
      players[buzzedPlayerIdx].score -= pts;
      showToast(`-${pts} for ${players[buzzedPlayerIdx].name}`, 'wrong-toast');
    }
    updateScoreboard();
  }

  markUsed(ci, qi);
  closeModal();

  if (checkAllUsed()) setTimeout(endGame, 500);
}

function markUsed(ci, qi) {
  const key = `${ci}-${qi}`;
  usedCells.add(key);
  const cell = document.getElementById(`cell-${ci}-${qi}`);
  if (cell) cell.classList.add('used');
}

function checkAllUsed() {
  const total = gameData.categories.length * POINTS.length;
  return usedCells.size >= total;
}

function closeModal() {
  document.getElementById('modal-bg').classList.remove('open');
  document.querySelector('.btn-wrong').style.display = '';
}

// ════════════════════════════════════════════════════════
//  END GAME
// ════════════════════════════════════════════════════════

function endGame() {
  const sorted = [...players].sort((a, b) => b.score - a.score);
  const res = document.getElementById('end-results');
  const medals = ['🥇','🥈','🥉','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣'];
  res.innerHTML = '';
  sorted.forEach((p, i) => {
    const row = document.createElement('div');
    row.className = 'result-row' + (i === 0 ? ' winner' : '');
    row.innerHTML = `
      <div class="result-rank">${medals[i]}</div>
      <div class="result-name" style="color:${p.color}">${p.name}</div>
      <div class="result-score ${p.score < 0 ? 'neg' : ''}">${p.score.toLocaleString()} ${themeData.currency}</div>
    `;
    res.appendChild(row);
  });
  showScreen('end-screen');
}

function playAgain() {
  players.forEach(p => p.score = 0);
  usedCells = new Set();
  activePlayerIdx = 0;
  buildBoard();
  renderScoreboard();
  showScreen('board-screen');
}

// ════════════════════════════════════════════════════════
//  UTILS
// ════════════════════════════════════════════════════════

let toastTimer;
function showToast(msg, cls='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + cls + ' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ════════════════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════════════════

initDefaultPlayers();
renderPlayerList();
applyTheme();
</script>
</body>
</html>
